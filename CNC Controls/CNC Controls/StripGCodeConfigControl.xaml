<UserControl x:Class="CNC.Controls.StripGCodeConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CNC.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="160" d:DesignWidth="310">
    <GroupBox x:Uid="grp_gcodeStrip" Header="GCode command stripping" HorizontalAlignment="Left" VerticalAlignment="Top" Height="Auto" Width="310">
        <Grid Margin="20,4,10,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Content="M6:" HorizontalAlignment="Right" Margin="0,2,8,2" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding Path=CommandIgnoreStates}" SelectedItem="{Binding Path=IgnoreM6, Mode=TwoWay}" HorizontalAlignment="Left" Margin="0,2,0,2" VerticalAlignment="Center" Width="90" Height="22"/>
            <Label Content="M7:" Grid.Row="1" HorizontalAlignment="Right" Margin="0,2,8,2" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Path=CommandIgnoreStates}" SelectedItem="{Binding Path=IgnoreM7, Mode=TwoWay}" HorizontalAlignment="Left" Margin="0,2,0,2" VerticalAlignment="Center" Width="90" Height="22"/>
            <Label Content="M8:" Grid.Row="2" HorizontalAlignment="Right" Margin="0,2,8,2" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Path=CommandIgnoreStates}" SelectedItem="{Binding Path=IgnoreM8, Mode=TwoWay}" HorizontalAlignment="Left" Margin="0,2,0,2" VerticalAlignment="Center" Width="90" Height="22"/>
            <Label Content="G61/G64:" Grid.Row="3" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,2,8,2"/>
            <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding Path=CommandIgnoreStates}" SelectedItem="{Binding Path=IgnoreG61G64, Mode=TwoWay}" HorizontalAlignment="Left" Margin="0,2,0,2" VerticalAlignment="Center" Width="90" Height="22"/>
        </Grid>
    </GroupBox>
</UserControl>
