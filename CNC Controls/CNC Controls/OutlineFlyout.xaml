<UserControl x:Class="CNC.Controls.OutlineFlyout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:CNC.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="120" d:DesignWidth="300" MaxWidth="300"
             Loaded="OutlineFlyout_Loaded">
    <UserControl.Resources>
        <system:String x:Uid="str_outlineFlyout" x:Key="MenuLabel">_Outline</system:String>
    </UserControl.Resources>
    <Border BorderBrush="{DynamicResource AppFlyoutBorderBrush}" BorderThickness="1" CornerRadius="3" Background="{DynamicResource AppFlyoutBackgroundBrush}">
        <Grid Height="120">
            <local:OutlineBaseControl Margin="0,15,0,0"/>
            <Button Content="×" Style="{DynamicResource FlyoutCloseButtonStyle}" Focusable="False" VerticalContentAlignment="Top" HorizontalAlignment="Left" Margin="285,0,0,0" VerticalAlignment="Top" Width="14" Height="18" Click="btn_Close"/>
        </Grid>
    </Border>
</UserControl>
